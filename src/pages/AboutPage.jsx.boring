                <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform" />
              </span>
            </motion.button>
            
            <motion.button
              whileHover={{ scale: 1.02, y: -2, borderColor: 'rgba(6,182,212,0.5)' }}
              whileTap={{ scale: 0.98 }}
              className="px-10 py-5 bg-white/5 border-2 border-white/20 rounded-xl font-semibold text-lg text-white backdrop-blur-sm hover:bg-white/10 transition-colors"
            >
              Get Started
            </motion.button>
          </motion.div>

          {/* Animated scroll indicator */}
          <motion.div
            className="absolute bottom-16 left-1/2 -translate-x-1/2"
            animate={{ y: [0, 15, 0] }}
            transition={{ duration: 2.5, repeat: Infinity, ease: "easeInOut" }}
          >
            <div className="w-8 h-14 border-2 border-cyan-500/40 rounded-full flex justify-center p-2">
              <motion.div
                className="w-2 h-3 bg-cyan-400 rounded-full shadow-lg shadow-cyan-400/50"
                animate={{ 
                  y: [0, 20, 0],
                  opacity: [1, 0.3, 1]
                }}
                transition={{ duration: 2.5, repeat: Infinity, ease: "easeInOut" }}
              />
            </div>
          </motion.div>
        </motion.div>
      </section>

      {/* ========== WHO WE ARE - FEATURE CARDS ========== */}
      <section className="relative py-32 px-6 lg:px-12 bg-zinc-950/50">
        <div className="max-w-7xl mx-auto">
          <motion.div
            initial={{ opacity: 0, y: 40 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true, margin: "-100px" }}
            transition={{ duration: 0.8 }}
            className="text-center mb-20"
          >
            <motion.div
