                <div className="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-blue-500/10 mb-6">
                  <Rocket className="w-8 h-8 text-blue-400" />
                </div>
                
                <h3 className="text-3xl font-bold text-white mb-4">Our Mission</h3>
                <p className="text-lg text-zinc-300 leading-relaxed mb-6">
                  Deliver working AI systems in fixed sprints—no open timelines, no vendor lock-in.
                </p>
                
                {/* Key points */}
                <div className="space-y-3">
