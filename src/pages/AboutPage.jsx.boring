        </div>
      </section>

      {/* ========== OUR CONVICTION ========== */}
      <section className="relative py-32 px-6 lg:px-12 bg-zinc-950/50">
        <div className="max-w-7xl mx-auto">
          <motion.div
            initial={{ opacity: 0, y: 40 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.8 }}
            className="text-center mb-20"
          >
            <h2 className="text-5xl lg:text-7xl font-bold text-white mb-6">
              Our <span className="bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text text-transparent">Conviction</span>
            </h2>
            <p className="text-2xl text-cyan-400 max-w-3xl mx-auto">
              That gap shaped everything we built
            </p>
          </motion.div>

          <div className="grid lg:grid-cols-2 gap-12 items-center mb-16">
            <motion.div
              initial={{ opacity: 0, x: -60 }}
              whileInView={{ opacity: 1, x: 0 }}
              viewport={{ once: true }}
              transition={{ duration: 1 }}
              whileHover={{ scale: 1.02 }}
              className="relative p-12 bg-gradient-to-br from-cyan-500/5 to-blue-500/5 border border-cyan-500/20 rounded-3xl"
            >
              <motion.div
                whileHover={{ scale: 1.1, rotate: 15 }}
                transition={{ duration: 0.5 }}
                className="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-cyan-500/20 to-blue-500/20 mb-6"
              >
                <Rocket className="w-10 h-10 text-cyan-400" />
              </motion.div>
              
              <h3 className="text-3xl font-bold text-white mb-4">
                We believed businesses needed a different path
              </h3>
              <p className="text-xl text-zinc-300 leading-relaxed">
                One that didn't sacrifice speed for structure—or independence for support.
              </p>
            </motion.div>

            <motion.div
              initial={{ opacity: 0, x: 60 }}
              whileInView={{ opacity: 1, x: 0 }}
              viewport={{ once: true }}
              transition={{ duration: 1, delay: 0.2 }}
            >
              <div className="space-y-6">
                {principles.map((principle, idx) => (
                  <motion.div
                    key={idx}
                    initial={{ opacity: 0, x: 40 }}
                    whileInView={{ opacity: 1, x: 0 }}
                    viewport={{ once: true }}
                    transition={{ duration: 0.6, delay: idx * 0.1 }}
                    whileHover={{ x: 10, scale: 1.02 }}
                    className="flex items-center gap-6 p-6 bg-zinc-900/50 border border-zinc-800 rounded-2xl hover:border-cyan-500/50 transition-all duration-300"
                  >
                    <motion.div
                      whileHover={{ rotate: 360, scale: 1.2 }}
                      transition={{ duration: 0.6 }}
                      className="flex-shrink-0 w-14 h-14 rounded-xl bg-cyan-500/10 flex items-center justify-center"
                    >
                      <principle.icon className="w-7 h-7 text-cyan-400" />
                    </motion.div>
                    <div className="flex-1">
                      <div className="text-white font-bold text-lg mb-1">{principle.title}</div>
                      <div className="text-zinc-400">{principle.description}</div>
                    </div>
                    <motion.div
                      initial={{ opacity: 0, x: -10 }}
                      whileInView={{ opacity: 1, x: 0 }}
                      transition={{ delay: 0.3 }}
                    >
                      <ArrowRight className="w-5 h-5 text-cyan-400" />
                    </motion.div>
                  </motion.div>
                ))}
              </div>
            </motion.div>
          </div>
        </div>
      </section>

      {/* ========== PHILOSOPHY ========== */}
      <section className="relative py-40 px-6 lg:px-12">
        <div className="max-w-4xl mx-auto">
          <motion.div
            initial={{ opacity: 0, y: 40 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 1 }}
            className="text-center"
          >
            <motion.div
              className="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-gradient-to-br from-cyan-500/20 to-blue-500/20 mb-10"
              animate={{
                scale: [1, 1.1, 1],
                rotate: [0, 10, -10, 0]
              }}
              transition={{
                duration: 5,
                repeat: Infinity,
                ease: "easeInOut"
              }}
            >
              <Sparkles className="w-12 h-12 text-cyan-400" />
            </motion.div>

            <h3 className="text-4xl lg:text-6xl font-bold text-white mb-10 leading-tight">
              That way of thinking <span className="text-cyan-400">hasn't changed.</span>
            </h3>
            
            <div className="space-y-8 text-xl text-zinc-300 leading-relaxed">
              <p>
                We believe the hardest part of AI isn't building models—
                <span className="text-white font-bold"> it's making the right decisions before anything is built.</span>
              </p>
              <p>
                We believe <span className="text-cyan-400 font-bold">speed only matters when grounded in discipline.</span>
              </p>
            </div>
          </motion.div>
        </div>
      </section>

      {/* ========== CLOSING STATEMENT ========== */}
      <section className="relative py-40 px-6 lg:px-12 overflow-hidden bg-gradient-to-b from-black via-zinc-950 to-black">
        {/* Animated background elements */}
        <motion.div
          className="absolute top-1/2 left-1/4 w-[500px] h-[500px] bg-cyan-500/10 rounded-full blur-3xl"
          animate={{
            scale: [1, 1.6, 1],
            x: [0, 120, 0],
            y: [0, -60, 0],
          }}
          transition={{
            duration: 20,
            repeat: Infinity,
            ease: "easeInOut"
          }}
        />
        <motion.div
          className="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-purple-500/10 rounded-full blur-3xl"
          animate={{
            scale: [1, 1.5, 1],
            x: [0, -120, 0],
            y: [0, 60, 0],
          }}
          transition={{
            duration: 18,
            repeat: Infinity,
            ease: "easeInOut",
            delay: 3
          }}
        />

        <motion.div
          initial={{ opacity: 0, y: 60, scale: 0.9 }}
          whileInView={{ opacity: 1, y: 0, scale: 1 }}
          viewport={{ once: true }}
          transition={{ 
            duration: 1.2,
            ease: [0.16, 1, 0.3, 1]
          }}
          className="max-w-5xl mx-auto text-center relative z-10"
        >
          <motion.div
            className="relative p-16 lg:p-20 bg-gradient-to-br from-zinc-900/80 to-black/80 border-2 border-cyan-500/30 rounded-3xl overflow-hidden backdrop-blur-xl"
            whileHover={{ scale: 1.02, borderColor: 'rgba(6,182,212,0.5)' }}
            transition={{ duration: 0.4 }}
          >
            {/* Animated gradient overlay */}
            <motion.div 
              className="absolute -inset-px bg-gradient-to-r from-cyan-500/20 via-blue-500/20 to-purple-500/20 rounded-3xl blur-2xl"
              animate={{
                opacity: [0.4, 0.7, 0.4],
                scale: [1, 1.1, 1],
              }}
              transition={{
                duration: 5,
                repeat: Infinity,
                ease: "easeInOut"
              }}
            />
            
            {/* Scan line effect */}
            <motion.div
              className="absolute inset-0 bg-gradient-to-b from-transparent via-cyan-500/10 to-transparent"
              animate={{
                y: ['-200%', '300%'],
              }}
              transition={{
                duration: 4,
                repeat: Infinity,
                ease: "linear",
                repeatDelay: 3
              }}
            />

            <div className="relative">
              {/* Rotating icon */}
              <motion.div 
                className="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-cyan-500/10 mb-8 relative"
                animate={{
                  rotate: [0, 360],
                }}
                transition={{
                  duration: 25,
                  repeat: Infinity,
                  ease: "linear"
                }}
              >
                <motion.div
                  className="absolute inset-0 rounded-2xl border-2 border-dashed border-cyan-500/40"
                  animate={{
                    rotate: [0, -360],
                    scale: [1, 1.2, 1]
                  }}
                  transition={{
                    rotate: { duration: 20, repeat: Infinity, ease: "linear" },
                    scale: { duration: 3, repeat: Infinity, ease: "easeInOut" }
                  }}
                />
                <Zap className="w-10 h-10 text-cyan-400" />
              </motion.div>
              
              <motion.h4 
                className="text-4xl lg:text-6xl font-bold text-white mb-6 leading-tight"
                initial={{ opacity: 0 }}
                whileInView={{ opacity: 1 }}
                transition={{ delay: 0.3, duration: 0.8 }}
              >
                That belief shaped <span className="bg-gradient-to-r from-cyan-400 to-blue-400 bg-clip-text text-transparent">Xendex AI</span>
              </motion.h4>
              
              <motion.p 
                className="text-2xl text-cyan-400 font-semibold"
                initial={{ opacity: 0 }}
                whileInView={{ opacity: 1 }}
                transition={{ delay: 0.5, duration: 0.8 }}
              >
                And it continues to shape everything we build.
              </motion.p>

              {/* Animated dots */}
              <div className="flex justify-center gap-3 mt-12">
                {[...Array(5)].map((_, i) => (
                  <motion.div
                    key={i}
                    className="w-3 h-3 rounded-full bg-gradient-to-r from-cyan-400 to-blue-400"
                    animate={{
                      scale: [1, 1.8, 1],
                      opacity: [0.4, 1, 0.4],
                    }}
                    transition={{
                      duration: 2.5,
                      repeat: Infinity,
                      delay: i * 0.2,
                      ease: "easeInOut"
                    }}
                  />
                ))}
              </div>
            </div>
          </motion.div>
        </motion.div>
      </section>

    </div>
  );
};

export default AboutPage;
